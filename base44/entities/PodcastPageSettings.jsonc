{
  "name": "PodcastPageSettings",
  "type": "object",
  "properties": {
    "podcast_page_title_he": {
      "type": "string"
    },
    "podcast_page_title_en": {
      "type": "string"
    },
    "podcast_description_he": {
      "type": "string"
    },
    "podcast_description_en": {
      "type": "string"
    },
    "podcast_bg_color": {
      "type": "string"
    },
    "podcast_spotify_url": {
      "type": "string"
    },
    "podcast_apple_url": {
      "type": "string"
    },
    "podcast_youtube_url": {
      "type": "string"
    },
    "podcast_google_url": {
      "type": "string"
    },
    "media_podcast": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "image",
              "video"
            ]
          },
          "file_url": {
            "type": "string"
          },
          "alt_he": {
            "type": "string"
          },
          "alt_en": {
            "type": "string"
          },
          "order_index": {
            "type": "number"
          }
        }
      }
    },
    "media_position_podcast": {
      "type": "string"
    }
  },
  "rls": {
    "write": {
      "user_condition": {
        "role": "admin"
      }
    }
  },
  "required": []
}